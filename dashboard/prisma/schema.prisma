generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Team {
  id          String       @id @default(cuid())
  name        String
  users       User[]
  ideas       Idea[]
  packs       Pack[]
  marketScans MarketScan[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model User {
  id            String         @id @default(cuid())
  cognitoId     String         @unique
  email         String         @unique
  name          String?
  teamId        String?
  team          Team?          @relation(fields: [teamId], references: [id])
  ideas         Idea[]
  packs         Pack[]
  marketScans   MarketScan[]
  subscription  Subscription?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([teamId])
}

model Idea {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId         String?
  team           Team?          @relation(fields: [teamId], references: [id])
  title          String
  description    String         @db.Text
  industry       String
  targetMarket   String
  technologies   String[]
  features       Json
  metadata       Json?
  currentVersion Int            @default(1)
  versions       IdeaVersion[]
  validations    Validation[]
  packs          Pack[]
  status         IdeaStatus     @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([teamId])
  @@index([teamId, status])
  @@index([createdAt])
}

model IdeaVersion {
  id        String        @id @default(cuid())
  ideaId    String
  idea      Idea          @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  version   Int
  snapshot  Json
  summary   String
  parentId  String?
  parent    IdeaVersion?  @relation("VersionBranch", fields: [parentId], references: [id])
  children  IdeaVersion[] @relation("VersionBranch")
  createdAt DateTime      @default(now())

  @@unique([ideaId, version])
  @@index([ideaId])
}

model Validation {
  id               String   @id @default(cuid())
  ideaId           String
  idea             Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  version          Int
  keywordScore     Int
  painPointScore   Int
  competitionScore Int
  revenueEstimate  Int
  overallScore     Int
  details          Json
  createdAt        DateTime @default(now())

  @@index([ideaId])
}

model Pack {
  id            String         @id @default(cuid())
  ideaId        String
  idea          Idea           @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId        String?
  team          Team?          @relation(fields: [teamId], references: [id])
  modules       String[]
  complexity    PackComplexity
  workUnitCount Int
  s3Key         String?
  downloadUrl   String?
  expiresAt     DateTime?
  status        PackStatus     @default(PENDING)
  errorMessage  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
  @@index([teamId])
  @@index([ideaId])
  @@index([status])
}

model Module {
  id           String   @id @default(cuid())
  name         String   @unique
  displayName  String
  description  String   @db.Text
  category     String
  workUnits    Json
  dependencies String[]
  tags         String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Subscription {
  id                   String           @id @default(cuid())
  userId               String           @unique
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier                 SubscriptionTier @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  ideasUsed            Int              @default(0)
  packsUsed            Int              @default(0)
  periodStart          DateTime         @default(now())
  periodEnd            DateTime
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model MarketScan {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId          String?
  team            Team?    @relation(fields: [teamId], references: [id])
  industry        String
  niche           String?
  status          String   @default("PENDING")
  opportunities   Json?
  metadata        Json?
  githubIssue     Int?
  githubIssueUrl  String?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([teamId])
  @@index([status])
}

enum IdeaStatus {
  PENDING
  DRAFT
  VALIDATED
  PACK_GENERATED
  ARCHIVED
}

enum PackStatus {
  PENDING
  GENERATING
  READY
  EXPIRED
  FAILED
}

enum PackComplexity {
  MVP
  STANDARD
  FULL
}

enum SubscriptionTier {
  FREE
  EXPLORER
  BUILDER
  AGENCY
}
